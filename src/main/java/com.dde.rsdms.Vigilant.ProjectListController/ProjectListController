	 @GetMapping("/addproject")
	    public String showform(Model model) {
		 List<OwnerMaster> owners = projectService.getAllOwnerNames();

		    model.addAttribute("owners", owners);
	        model.addAttribute("addproject", new ProjectList());
	        return "addProject";
	    }
	 @GetMapping("/projectList")
	 public String projectList(
	         @RequestParam(defaultValue = "1") int page,
	         Model model) {

	     int pageSize = 10;
	     int offset = (page - 1) * pageSize;

	     List<ProjectList> list = projectService.getProjectByPage(offset, pageSize);
         
	     List<OwnerMaster> owners = projectService.getAllOwnerNames();
         
	     Map<Integer, String> ownerMap = new HashMap<>();

	     for (OwnerMaster o : owners) {
	         ownerMap.put(o.getOwnercode(), o.getOwnername());
	     }

	     int totalRecords = projectService.getTotalRecords();
	     int totalPages = (int) Math.ceil((double) totalRecords / pageSize);
	     int start = (page - 1) * pageSize + 1;
	     int end = Math.min(page * pageSize, totalRecords);
	     model.addAttribute("addproject", list);
	     model.addAttribute("ownerMap", ownerMap);

	     model.addAttribute("currentPage", page);
	     model.addAttribute("totalPages", totalPages);
	     model.addAttribute("startEntry", start);
	     model.addAttribute("endEntry", end);
	     model.addAttribute("totalEntries", totalRecords);
	     return "projectList";
	 }
	 @PostMapping("/save3")
	 public String saveform(@ModelAttribute ProjectList addproject) {

		    try {

		        Connection con = datasource.getConnection();

		        String sql = "INSERT INTO projectmaster (projectcode, projectname, projectlocation, projectdescription, openinglattitude, openinglongitude, ownercode) VALUES (?, ?, ?, ?, ?, ?, ?)";

		        PreparedStatement ps = con.prepareStatement(sql);
		
		        ps.setInt(1, addproject.getProjectCode());
		        ps.setString(2, addproject.getProjectName());
		        ps.setString(3, addproject.getProjectLocation());
		        ps.setString(4, addproject.getProjectDescription());
		        ps.setString(5, addproject.getOpeningLattitude());
		        ps.setString(6, addproject.getOpeningLongitude());
		        ps.setInt(7, addproject.getOwnerCode());

		        ps.executeUpdate();

		        ps.close();
		        con.close();

		    } catch (Exception e) {
		        e.printStackTrace();
		    }

		    int totalRecords = 0;

		    try {

		        Connection con2 = datasource.getConnection();

		        PreparedStatement ps2 =
		        con2.prepareStatement("SELECT COUNT(*) FROM projectmaster");

		        ResultSet rs = ps2.executeQuery();

		        if(rs.next()) {
		            totalRecords = rs.getInt(1);
		        }

		        rs.close();
		        ps2.close();
		        con2.close();

		    } catch (Exception e) {
		        e.printStackTrace();
		    }

		    int pageSize = 10;

		    int lastPage =
		    (int)Math.ceil((double) totalRecords / pageSize);

		    return "redirect:/projectList?page=" + lastPage + "&success=added";
		}

	    @PostMapping("/updates")
	    public String update(@ModelAttribute ProjectList addproject) {

	        try {
