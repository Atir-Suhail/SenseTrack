	    @GetMapping("/delete")
	    public String delete(@RequestParam("projectCode") Integer projectCode) {

	        try {
	            Connection con = datasource.getConnection();

	            String sql = "delete from projectmaster where projectcode=?";
	            PreparedStatement ps = con.prepareStatement(sql);

	            ps.setInt(1, projectCode);

	            ps.executeUpdate();

	            ps.close();
	            con.close();
	            System.out.println("Data Deleted Successfully");

	        } catch (Exception e) {
	            e.printStackTrace();
	        }

	        return "redirect:/projectList?success=deleted";
	    }

	    @GetMapping("/edit")
	    public String edit(@RequestParam("projectCode") Integer projectCode, Model model) {

	        ProjectList pl = new ProjectList();

	        try {
	            Connection con = datasource.getConnection();

	            String sql = "select * from projectmaster where projectcode=?";
	            PreparedStatement ps = con.prepareStatement(sql);

	            ps.setInt(1, projectCode);

	            var rs = ps.executeQuery();

	            if (rs.next()) {
	                pl.setProjectCode(rs.getInt("projectCode"));
	                pl.setProjectName(rs.getString("projectName"));
	                pl.setProjectLocation(rs.getString("projectLocation"));
	                pl.setProjectDescription(rs.getString("projectDescription"));
	                pl.setOpeningLattitude(rs.getString("openingLattitude"));
	                pl.setOpeningLongitude(rs.getString("openingLongitude"));
	                pl.setOwnerCode(rs.getInt("ownercode"));
	            }

	            rs.close();
	            ps.close();
	            con.close();

	        } catch (Exception e) {
	            e.printStackTrace();
	        }

	        
	        List<OwnerMaster> owners = projectService.getAllOwnerNames();
	        model.addAttribute("owners", owners);

	       
	        model.addAttribute("addproject", pl);

	        return "addProject";
	    }
	    
	    @GetMapping("/exportExcel")
	    public void exportExcel(HttpServletResponse response)
	    throws Exception {

	    response.setContentType(
	    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

	    response.setHeader(
	    "Content-Disposition",
	    "attachment; filename=Project_List.xlsx");

	    List<ProjectList> list =
	    projectService.getAllProject();

	    Workbook workbook = new XSSFWorkbook();
	    Sheet sheet = (Sheet) workbook.createSheet("Projects");

	    Row header = ((org.apache.poi.ss.usermodel.Sheet) sheet).createRow(0);

	    header.createCell(0).setCellValue("S.No");
	    header.createCell(1).setCellValue("Project Name");
	    header.createCell(2).setCellValue("Location");
	    header.createCell(3).setCellValue("Project Description");
	    header.createCell(4).setCellValue("Lattitude");
	    header.createCell(5).setCellValue("Longitude");
	    header.createCell(6).setCellValue("Owner");

	    int rowNum = 1;

	    for(ProjectList p : list){

	    Row row = ((org.apache.poi.ss.usermodel.Sheet) sheet).createRow(rowNum++);

	    row.createCell(0).setCellValue(p.getProjectCode());
	    row.createCell(1).setCellValue(p.getProjectName());
	    row.createCell(2).setCellValue(p.getProjectLocation());
	    row.createCell(3).setCellValue(p.getProjectDescription());
	    row.createCell(4).setCellValue(p.getOpeningLattitude());
	    row.createCell(5).setCellValue(p.getOpeningLattitude());
	    row.createCell(6).setCellValue(p.getOwnerCode());

	    }

	    workbook.write(response.getOutputStream());
	    workbook.close();
	    }
	}


