	            String sql = "update projectmaster set projectname=?, projectlocation=?, projectdescription=?, openinglattitude=?, openinglongitude=?, ownercode=? where projectcode=?";
	            PreparedStatement ps = con.prepareStatement(sql);

	            ps.setString(1, addproject.getProjectName());
